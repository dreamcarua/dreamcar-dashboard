# ============================================================
# DreamCar Dashboard — Environment Variables
# ============================================================
# Скопіюй цей файл як .env і заповни справжніми значеннями.
# .env у .gitignore — НЕ комітити!
#
# Документація: див. CLAUDE.md та SECURITY.md
# ============================================================

# === Database (MySQL 8.4 на fincheck.mysql.network) ===
DB_HOST=fincheck.mysql.network
DB_PORT=10145
DB_NAME=dreamcar_utm
DB_USER=dreamcar_utm
DB_PASS=

# === SendPulse CRM ===
SENDPULSE_ID=
SENDPULSE_SECRET=

# === Google Sheets ===
GOOGLE_SPREADSHEET_ID=
# GOOGLE_CREDENTIALS_FILE = data/google_credentials.json (положи файл, не комітимо)

# === Telegram (DreamCar Dashboard notifications) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === GitHub Webhook + Sync ===
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO_URL=https://USER:PAT@github.com/dreamcarua/dreamcar-dashboard.git

# === OpenAI (git auto commit messages) ===
OPENAI_API_KEY=

# === Telegram (Git Sync — Александр) ===
GIT_SYNC_TG_TOKEN=
GIT_SYNC_TG_CHAT=
GIT_SYNC_TG_MENTION=

# === App ===
BASE_URL=https://ticket.ai-platform.space/dashboard/utm-dashboard/
APP_ENV=production
